# Copy to .env on the VPS and fill in. Read by docker-compose.yml; .env is
# gitignored so none of this lands in the public repo.

# Public hostname the game is served on (no scheme). Must match the tunnel's
# public hostname and the Cloudflare Access application domain.
PUZZLE_HOSTNAME=puzzle.example.com

# Cloudflare Tunnel token: Zero Trust -> Networks -> Tunnels -> your tunnel.
TUNNEL_TOKEN=

# Optional: store puzzle images in S3 instead of the docker volume.
# Leave S3_BUCKET empty to use local disk.
S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
